# /etc/systemd/system/k3s.service.env
#
# Reserves CPU/memory for system components so that a CPU-hungry workload
# (Frigate during an inference burst) cannot starve the kubelet, the API
# server, or etcd.
#
# Values are conservative for an i5-6600 (4 cores, 16 GB). Adjust for
# your node size — the principle is "leave a budget the workload cannot eat."

K3S_KUBELET_ARG="--kube-reserved=cpu=500m,memory=512Mi --system-reserved=cpu=500m,memory=512Mi --eviction-hard=memory.available<200Mi,nodefs.available<10%"
